    "    }\n",
    "   },\n",
    "   \"source\": [\n",
    "    \"df_ex11 = df.copy()\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Calculate IQR bounds for Price\\n\",\n",
    "    \"Q1 = df_ex11['Price'].quantile(0.25)\\n\",\n",
    "    \"Q3 = df_ex11['Price'].quantile(0.75)\\n\",\n",
    "    \"IQR = Q3 - Q1\\n\",\n",
    "    \"lower = Q1 - 1.5 * IQR\\n\",\n",
    "    \"upper = Q3 + 1.5 * IQR\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Remove outliers (keep only rows within bounds)\\n\",\n",
    "    \"df_no_outliers = df_ex11[(df_ex11['Price'] >= lower) & (df_ex11['Price'] <= upper)]\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Compare statistics\\n\",\n",
    "    \"print(\\\"Before removing outliers:\\\")\\n\",\n",
    "    \"print(f\\\"  Count: {len(df_ex11)}\\\")\\n\",\n",
    "    \"print(f\\\"  Mean: ${df_ex11['Price'].mean():,.0f}\\\")\\n\",\n",
    "    \"print(f\\\"  Median: ${df_ex11['Price'].median():,.0f}\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"print(\\\"\\\\nAfter removing outliers:\\\")\\n\",\n",
    "    \"print(f\\\"  Count: {len(df_no_outliers)}\\\")\\n\",\n",
    "    \"print(f\\\"  Mean: ${df_no_outliers['Price'].mean():,.0f}\\\")\\n\",\n",
    "    \"print(f\\\"  Median: ${df_no_outliers['Price'].median():,.0f}\\\")\\n\",\n",
    "    \"print(f\\\"  Removed: {len(df_ex11) - len(df_no_outliers)} rows ({(1 - len(df_no_outliers)/len(df_ex11))*100:.1f}%)\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Visualize\\n\",\n",
    "    \"fig, axes = plt.subplots(1, 2, figsize=(12, 5))\\n\",\n",
    "    \"sns.boxplot(data=df_ex11, y='Price', ax=axes[0])\\n\",\n",
    "    \"axes[0].set_title('With Outliers')\\n\",\n",
    "    \"axes[0].set_ylabel('Price ($)')\\n\",\n",
    "    \"\\n\",\n",
    "    \"sns.boxplot(data=df_no_outliers, y='Price', ax=axes[1])\\n\",\n",
    "    \"axes[1].set_title('Without Outliers')\\n\",\n",
    "    \"axes[1].set_ylabel('Price ($)')\\n\",\n",
    "    \"\\n\",\n",
