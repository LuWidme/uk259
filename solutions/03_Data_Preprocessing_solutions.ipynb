    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"---\\n\",\n",
    "    \"## Exercise Solutions\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"### Exercise 1 Solution: Missing Value Analysis\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"metadata\": {\n",
    "    \"ExecuteTime\": {\n",
    "     \"end_time\": \"2026-03-10T10:28:53.422530600Z\",\n",
    "     \"start_time\": \"2026-03-10T10:28:53.392424600Z\"\n",
    "    }\n",
    "   },\n",
    "   \"source\": [\n",
    "    \"# Calculate percentage of missing values for each column\\n\",\n",
    "    \"missing_percentages = (df.isnull().sum() / len(df)) * 100\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Filter for columns with more than 5% missing\\n\",\n",
    "    \"columns_with_high_missing = missing_percentages[missing_percentages > 5]\\n\",\n",
    "    \"\\n\",\n",
    "    \"print(\\\"Columns with >5% missing values:\\\")\\n\",\n",
    "    \"print(columns_with_high_missing.sort_values(ascending=False))\"\n",
    "   ],\n",
    "   \"outputs\": [\n",
    "    {\n",
    "     \"name\": \"stdout\",\n",
    "     \"output_type\": \"stream\",\n",
    "     \"text\": [\n",
    "      \"Columns with >5% missing values:\\n\",\n",
    "      \"BuildingArea    47.496318\\n\",\n",
    "      \"YearBuilt       39.580265\\n\",\n",
    "      \"CouncilArea     10.081001\\n\",\n",
    "      \"dtype: float64\\n\"\n",
    "     ]\n",
    "    }\n",
    "   ],\n",
    "   \"execution_count\": 23\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"**Explanation:**\\n\",\n",
    "    \"- `df.isnull().sum()` counts missing values per column\\n\",\n",
    "    \"- Dividing by `len(df)` gives the proportion\\n\",\n",
    "    \"- Multiplying by 100 converts to percentage\\n\",\n",
    "    \"- Boolean indexing `[missing_percentages > 5]` filters the results\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"### Exercise 2 Solution: Smart Missing Value Imputation\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"metadata\": {\n",
    "    \"ExecuteTime\": {\n",
    "     \"end_time\": \"2026-03-10T10:28:53.449269400Z\",\n",
    "     \"start_time\": \"2026-03-10T10:28:53.425532800Z\"\n",
    "    }\n",
    "   },\n",
    "   \"source\": [\n",
    "    \"df_ex2 = df.copy()\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Count missing values\\n\",\n",
    "    \"missing_count = df_ex2['Car'].isnull().sum()\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Calculate median\\n\",\n",
    "    \"median_value = df_ex2['Car'].median()\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Fill missing values\\n\",\n",
    "    \"df_ex2['Car'].fillna(median_value, inplace=True)\\n\",\n",
    "    \"\\n\",\n",
    "    \"print(f\\\"Missing values before: {missing_count}\\\")\\n\",\n",
    "    \"print(f\\\"Median value used: {median_value}\\\")\\n\",\n",
    "    \"print(f\\\"Missing values after: {df_ex2['Car'].isnull().sum()}\\\")\"\n",
    "   ],\n",
    "   \"outputs\": [\n",
    "    {\n",
    "     \"name\": \"stdout\",\n",
    "     \"output_type\": \"stream\",\n",
    "     \"text\": [\n",
    "      \"Missing values before: 62\\n\",\n",
    "      \"Median value used: 2.0\\n\",\n",
    "      \"Missing values after: 0\\n\"\n",
    "     ]\n",
    "    },\n",
    "    {\n",
    "     \"name\": \"stderr\",\n",
    "     \"output_type\": \"stream\",\n",
    "     \"text\": [\n",
    "      \"C:\\\\Users\\\\luca.widmer\\\\AppData\\\\Local\\\\Temp\\\\ipykernel_52020\\\\3222909705.py:10: FutureWarning: A value is trying to be set on a copy of a DataFrame or Series through chained assignment using an inplace method.\\n\",\n",
    "      \"The behavior will change in pandas 3.0. This inplace method will never work because the intermediate object on which we are setting values always behaves as a copy.\\n\",\n",
    "      \"\\n\",\n",
    "      \"For example, when doing 'df[col].method(value, inplace=True)', try using 'df.method({col: value}, inplace=True)' or df[col] = df[col].method(value) instead, to perform the operation inplace on the original object.\\n\",\n",
    "      \"\\n\",\n",
    "      \"\\n\",\n",
    "      \"  df_ex2['Car'].fillna(median_value, inplace=True)\\n\"\n",
    "     ]\n",
    "    }\n",
    "   ],\n",
    "   \"execution_count\": 24\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"**Explanation:**\\n\",\n",
    "    \"- `.median()` is preferred over `.mean()` for skewed distributions\\n\",\n",
    "    \"- `inplace=True` modifies the DataFrame directly\\n\",\n",
    "    \"- Median is robust to outliers (e.g., if one property has 10 car spaces, it won't skew the imputation)\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"### Exercise 3 Solution: Detect Outliers in Landsize\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"metadata\": {\n",
    "    \"ExecuteTime\": {\n",
    "     \"end_time\": \"2026-03-10T10:28:53.492482900Z\",\n",
    "     \"start_time\": \"2026-03-10T10:28:53.466794100Z\"\n",
    "    }\n",
    "   },\n",
    "   \"source\": [\n",
    "    \"# Calculate quartiles and IQR\\n\",\n",
    "    \"Q1 = df['Landsize'].quantile(0.25)\\n\",\n",
    "    \"Q3 = df['Landsize'].quantile(0.75)\\n\",\n",
    "    \"IQR = Q3 - Q1\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Calculate bounds\\n\",\n",
    "    \"lower_bound = Q1 - 1.5 * IQR\\n\",\n",
    "    \"upper_bound = Q3 + 1.5 * IQR\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Find outliers\\n\",\n",
    "    \"outliers = df[(df['Landsize'] < lower_bound) | (df['Landsize'] > upper_bound)]\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Find maximum\\n\",\n",
    "    \"max_landsize = df['Landsize'].max()\\n\",\n",
    "    \"\\n\",\n",
    "    \"print(f\\\"Q1: {Q1}, Q3: {Q3}, IQR: {IQR}\\\")\\n\",\n",
    "    \"print(f\\\"Outlier bounds: [{lower_bound:.2f}, {upper_bound:.2f}]\\\")\\n\",\n",
    "    \"print(f\\\"Number of landsize outliers: {len(outliers)} ({len(outliers)/len(df)*100:.1f}%)\\\")\\n\",\n",
    "    \"print(f\\\"Maximum landsize: {max_landsize} sq.m\\\")\"\n",
    "   ],\n",
    "   \"outputs\": [\n",
    "    {\n",
    "     \"name\": \"stdout\",\n",
    "     \"output_type\": \"stream\",\n",
    "     \"text\": [\n",
    "      \"Q1: 177.0, Q3: 651.0, IQR: 474.0\\n\",\n",
    "      \"Outlier bounds: [-534.00, 1362.00]\\n\",\n",
    "      \"Number of landsize outliers: 368 (2.7%)\\n\",\n",
    "      \"Maximum landsize: 433014.0 sq.m\\n\"\n",
    "     ]\n",
    "    }\n",
    "   ],\n",
    "   \"execution_count\": 25\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"**Explanation:**\\n\",\n",
    "    \"- IQR method: outliers are values < Q1 - 1.5×IQR or > Q3 + 1.5×IQR\\n\",\n",
    "    \"- The `|` operator means \\\"or\\\" in boolean indexing\\n\",\n",
    "    \"- The large maximum landsize (433,014 sq.m) is clearly an outlier - likely a data entry error!\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"### Exercise 4 Solution: Standardize Multiple Columns\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"metadata\": {\n",
    "    \"ExecuteTime\": {\n",
    "     \"end_time\": \"2026-03-10T10:28:53.526882100Z\",\n",
    "     \"start_time\": \"2026-03-10T10:28:53.496549400Z\"\n",
    "    }\n",
    "   },\n",
    "   \"source\": [\n",
    "    \"from sklearn.preprocessing import StandardScaler\\n\",\n",
    "    \"\\n\",\n",
    "    \"df_ex4 = df.copy()\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Step 1: Fill missing values in BuildingArea\\n\",\n",
    "    \"df_ex4['BuildingArea'].fillna(df_ex4['BuildingArea'].median(), inplace=True)\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Step 2-3: Create scaler and standardize all three columns\\n\",\n",
    "    \"scaler = StandardScaler()\\n\",\n",
    "    \"df_ex4[['Distance_scaled', 'Landsize_scaled', 'BuildingArea_scaled']] = scaler.fit_transform(\\n\",\n",
    "    \"    df_ex4[['Distance', 'Landsize', 'BuildingArea']]\\n\",\n",
    "    \")\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Step 4: Verify\\n\",\n",
    "    \"print(\\\"Mean and Std of scaled columns:\\\")\\n\",\n",
    "    \"for col in ['Distance_scaled', 'Landsize_scaled', 'BuildingArea_scaled']:\\n\",\n",
    "    \"    print(f\\\"{col}: mean={df_ex4[col].mean():.10f}, std={df_ex4[col].std():.4f}\\\")\"\n",
    "   ],\n",
    "   \"outputs\": [\n",
    "    {\n",
    "     \"name\": \"stdout\",\n",
    "     \"output_type\": \"stream\",\n",
    "     \"text\": [\n",
    "      \"Mean and Std of scaled columns:\\n\",\n",
    "      \"Distance_scaled: mean=-0.0000000000, std=1.0000\\n\",\n",
    "      \"Landsize_scaled: mean=0.0000000000, std=1.0000\\n\",\n",
    "      \"BuildingArea_scaled: mean=-0.0000000000, std=1.0000\\n\"\n",
    "     ]\n",
    "    },\n",
    "    {\n",
    "     \"name\": \"stderr\",\n",
    "     \"output_type\": \"stream\",\n",
    "     \"text\": [\n",
    "      \"C:\\\\Users\\\\luca.widmer\\\\AppData\\\\Local\\\\Temp\\\\ipykernel_52020\\\\784851103.py:6: FutureWarning: A value is trying to be set on a copy of a DataFrame or Series through chained assignment using an inplace method.\\n\",\n",
    "      \"The behavior will change in pandas 3.0. This inplace method will never work because the intermediate object on which we are setting values always behaves as a copy.\\n\",\n",
    "      \"\\n\",\n",
    "      \"For example, when doing 'df[col].method(value, inplace=True)', try using 'df.method({col: value}, inplace=True)' or df[col] = df[col].method(value) instead, to perform the operation inplace on the original object.\\n\",\n",
    "      \"\\n\",\n",
    "      \"\\n\",\n",
    "      \"  df_ex4['BuildingArea'].fillna(df_ex4['BuildingArea'].median(), inplace=True)\\n\"\n",
    "     ]\n",
    "    }\n",
    "   ],\n",
    "   \"execution_count\": 26\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"**Explanation:**\\n\",\n",
    "    \"- Must handle missing values BEFORE scaling (StandardScaler can't handle NaN)\\n\",\n",
    "    \"- Pass all columns to scale at once: `df[['col1', 'col2', 'col3']]`\\n\",\n",
    "    \"- Mean should be ~0 (within floating point precision)\\n\",\n",
    "    \"- Std should be ~1.0 (exactly 1.0 when using sample std)\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"### Exercise 5 Solution: Normalize Price to [0, 1]\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"metadata\": {\n",
    "    \"ExecuteTime\": {\n",
    "     \"end_time\": \"2026-03-10T10:28:53.557456300Z\",\n",
    "     \"start_time\": \"2026-03-10T10:28:53.528880900Z\"\n",
    "    }\n",
    "   },\n",
    "   \"source\": [\n",
    "    \"from sklearn.preprocessing import MinMaxScaler\\n\",\n",
    "    \"\\n\",\n",
    "    \"df_ex5 = df.copy()\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Create normalizer and transform\\n\",\n",
    "    \"normalizer = MinMaxScaler()\\n\",\n",
    "    \"df_ex5['Price_normalized'] = normalizer.fit_transform(df_ex5[['Price']])\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Find house closest to normalized price of 0.5\\n\",\n",
    "    \"median_house = df_ex5.iloc[(df_ex5['Price_normalized'] - 0.5).abs().argmin()]\\n\",\n",
    "    \"\\n\",\n",
    "    \"print(f\\\"Normalized price range: [{df_ex5['Price_normalized'].min()}, {df_ex5['Price_normalized'].max()}]\\\")\\n\",\n",
    "    \"print(f\\\"\\\\nHouse with price closest to median (0.5):\\\")\\n\",\n",
    "    \"print(f\\\"Address: {median_house['Address']}\\\")\\n\",\n",
    "    \"print(f\\\"Actual Price: ${median_house['Price']:,.0f}\\\")\\n\",\n",
    "    \"print(f\\\"Normalized Price: {median_house['Price_normalized']:.4f}\\\")\"\n",
    "   ],\n",
    "   \"outputs\": [\n",
    "    {\n",
    "     \"name\": \"stdout\",\n",
    "     \"output_type\": \"stream\",\n",
    "     \"text\": [\n",
    "      \"Normalized price range: [0.0, 0.9999999999999999]\\n\",\n",
    "      \"\\n\",\n",
    "      \"House with price closest to median (0.5):\\n\",\n",
    "      \"Address: 3 Mary St\\n\",\n",
    "      \"Actual Price: $4,525,000\\n\",\n",
    "      \"Normalized Price: 0.4980\\n\"\n",
    "     ]\n",
    "    }\n",
    "   ],\n",
    "   \"execution_count\": 27\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"**Explanation:**\\n\",\n",
    "    \"- MinMaxScaler transforms to [0, 1] range\\n\",\n",
    "    \"- `(df['Price_normalized'] - 0.5).abs()` calculates distance from 0.5\\n\",\n",
    "    \"- `.argmin()` finds the index of the minimum distance\\n\",\n",
    "    \"- `.iloc[]` retrieves the row at that index\\n\",\n",
    "    \"- A normalized value of 0.5 represents the middle of the price range\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"### Exercise 6 Solution: Label Encode Multiple Categorical Columns\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"metadata\": {\n",
    "    \"ExecuteTime\": {\n",
    "     \"end_time\": \"2026-03-10T10:28:53.588673300Z\",\n",
    "     \"start_time\": \"2026-03-10T10:28:53.560851500Z\"\n",
    "    }\n",
    "   },\n",
    "   \"source\": [\n",
    "    \"df_ex6 = df.copy()\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Encode both columns\\n\",\n",
    "    \"df_ex6['Method_encoded'] = df_ex6['Method'].astype('category').cat.codes\\n\",\n",
    "    \"df_ex6['SellerG_encoded'] = df_ex6['SellerG'].astype('category').cat.codes\\n\",\n",
    "    \"\\n\",\n",
    "    \"print(\\\"Method encoding mapping:\\\")\\n\",\n",
    "    \"print(df_ex6[['Method', 'Method_encoded']].drop_duplicates().sort_values('Method_encoded'))\\n\",\n",
    "    \"\\n\",\n",
    "    \"print(f\\\"\\\\nNumber of unique sellers: {df_ex6['SellerG'].nunique()}\\\")\"\n",
    "   ],\n",
    "   \"outputs\": [\n",
    "    {\n",
    "     \"name\": \"stdout\",\n",
    "     \"output_type\": \"stream\",\n",
    "     \"text\": [\n",
    "      \"Method encoding mapping:\\n\",\n",
    "      \"    Method  Method_encoded\\n\",\n",
    "      \"3       PI               0\\n\",\n",
    "      \"0        S               1\\n\",\n",
    "      \"462     SA               2\\n\",\n",
    "      \"2       SP               3\\n\",\n",
    "      \"4       VB               4\\n\",\n",
    "      \"\\n\",\n",
    "      \"Number of unique sellers: 268\\n\"\n",
    "     ]\n",
    "    }\n",
    "   ],\n",
    "   \"execution_count\": 28\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"**Explanation:**\\n\",\n",
    "    \"- `.astype('category')` converts to categorical type\\n\",\n",
    "    \"- `.cat.codes` assigns integer codes (alphabetically by default)\\n\",\n",
    "    \"- 268 unique sellers means 268 different encoded values (0-267)\\n\",\n",
    "    \"- Label encoding is appropriate here for tree-based models, but use one-hot for linear models\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"### Exercise 7 Solution: One-Hot Encode Property Type\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"metadata\": {\n",
    "    \"ExecuteTime\": {\n",
    "     \"end_time\": \"2026-03-10T10:28:53.621789Z\",\n",
    "     \"start_time\": \"2026-03-10T10:28:53.591674300Z\"\n",
    "    }\n",
    "   },\n",
    "   \"source\": [\n",
    "    \"df_ex7 = df.copy()\\n\",\n",
    "    \"\\n\",\n",
    "    \"original_cols = df_ex7.shape[1]\\n\",\n",
    "    \"\\n\",\n",
    "    \"# One-hot encode Type column\\n\",\n",
    "    \"df_ex7 = pd.get_dummies(df_ex7, columns=['Type'], prefix='PropertyType', drop_first=True)\\n\",\n",
    "    \"\\n\",\n",
    "    \"new_cols = df_ex7.shape[1]\\n\",\n",
    "    \"\\n\",\n",
    "    \"print(f\\\"Columns before: {original_cols}\\\")\\n\",\n",
    "    \"print(f\\\"Columns after: {new_cols}\\\")\\n\",\n",
    "    \"print(f\\\"Columns added: {new_cols - original_cols}\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Show the new columns\\n\",\n",
