    "   \"cell_type\": \"markdown\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"---\\n\",\n",
    "    \"\\n\",\n",
    "    \"## Part 1: Loading and Exploring the Data\\n\",\n",
    "    \"\\n\",\n",
    "    \"We'll use the **MNIST dataset**: 70,000 images of handwritten digits (0-9).\\n\",\n",
    "    \"\\n\",\n",
    "    \"**Dataset details:**\\n\",\n",
    "    \"- 60,000 training images\\n\",\n",
    "    \"- 10,000 test images\\n\",\n",
    "    \"- Each image: 28×28 pixels (grayscale)\\n\",\n",
    "    \"- Labels: 0, 1, 2, ..., 9\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"metadata\": {\n",
    "    \"ExecuteTime\": {\n",
    "     \"end_time\": \"2026-01-13T13:26:54.107638600Z\",\n",
    "     \"start_time\": \"2026-01-13T13:26:53.933415400Z\"\n",
    "    }\n",
    "   },\n",
    "   \"source\": [\n",
    "    \"# Load MNIST dataset (built into Keras!)\\n\",\n",
    "    \"(x_train, y_train), (x_test, y_test) = keras.datasets.mnist.load_data()\\n\",\n",
    "    \"\\n\",\n",
    "    \"print(\\\"Training data shape:\\\", x_train.shape)\\n\",\n",
    "    \"print(\\\"Training labels shape:\\\", y_train.shape)\\n\",\n",
    "    \"print(\\\"\\\\nTest data shape:\\\", x_test.shape)\\n\",\n",
    "    \"print(\\\"Test labels shape:\\\", y_test.shape)\\n\",\n",
    "    \"\\n\",\n",
    "    \"print(\\\"\\\\n📊 Dataset Summary:\\\")\\n\",\n",
    "    \"print(f\\\"  • {len(x_train):,} training images\\\")\\n\",\n",
    "    \"print(f\\\"  • {len(x_test):,} test images\\\")\\n\",\n",
    "    \"print(f\\\"  • Image size: {x_train.shape[1]}×{x_train.shape[2]} pixels\\\")\\n\",\n",
    "    \"print(f\\\"  • Pixel values range: {x_train.min()} to {x_train.max()}\\\")\"\n",
    "   ],\n",
    "   \"outputs\": [\n",
    "    {\n",
    "     \"name\": \"stdout\",\n",
    "     \"output_type\": \"stream\",\n",
    "     \"text\": [\n",
    "      \"Training data shape: (60000, 28, 28)\\n\",\n",
    "      \"Training labels shape: (60000,)\\n\",\n",
    "      \"\\n\",\n",
    "      \"Test data shape: (10000, 28, 28)\\n\",\n",
    "      \"Test labels shape: (10000,)\\n\",\n",
    "      \"\\n\",\n",
    "      \"📊 Dataset Summary:\\n\",\n",
    "      \"  • 60,000 training images\\n\",\n",
    "      \"  • 10,000 test images\\n\",\n",
    "      \"  • Image size: 28×28 pixels\\n\",\n",
    "      \"  • Pixel values range: 0 to 255\\n\"\n",
    "     ]\n",
    "    }\n",
    "   ],\n",
    "   \"execution_count\": 2\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"### Visualize Some Examples\\n\",\n",
    "    \"\\n\",\n",
    "    \"Let's look at what the data actually looks like:\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"metadata\": {\n",
    "    \"ExecuteTime\": {\n",
    "     \"end_time\": \"2026-01-13T13:26:54.442091700Z\",\n",
    "     \"start_time\": \"2026-01-13T13:26:54.119715200Z\"\n",
    "    }\n",
    "   },\n",
    "   \"source\": [\n",
    "    \"# Display first 10 training images\\n\",\n",
    "    \"plt.figure(figsize=(15, 3))\\n\",\n",
    "    \"for i in range(10):\\n\",\n",
    "    \"    plt.subplot(1, 10, i + 1)\\n\",\n",
    "    \"    plt.imshow(x_train[i], cmap='gray')\\n\",\n",
    "    \"    plt.title(f'Label: {y_train[i]}', fontsize=10)\\n\",\n",
    "    \"    plt.axis('off')\\n\",\n",
    "    \"plt.suptitle('Sample MNIST Images', fontsize=14, fontweight='bold', y=1.05)\\n\",\n",
    "    \"plt.tight_layout()\\n\",\n",
    "    \"plt.show()\\n\",\n",
