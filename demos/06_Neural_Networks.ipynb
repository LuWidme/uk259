    "    {\n",
    "     \"name\": \"stdout\",\n",
    "     \"output_type\": \"stream\",\n",
    "     \"text\": [\n",
    "      \"Raw output (logits):\\n\",\n",
    "      \"[-0.2488943   0.30804095  0.22907536  0.5281946  -0.21155126 -0.0523155\\n\",\n",
    "      \"  0.6018575  -0.2087282  -0.27015507 -0.11056635]\\n\",\n",
    "      \"\\n\",\n",
    "      \"These are called 'logits' - raw scores for each class.\\n\",\n",
    "      \"Higher score = more confident prediction\\n\",\n",
    "      \"\\n\",\n",
    "      \"Probabilities (after softmax):\\n\",\n",
    "      \"  Digit 0: 7.0%\\n\",\n",
    "      \"  Digit 1: 12.2%\\n\",\n",
    "      \"  Digit 2: 11.3%\\n\",\n",
    "      \"  Digit 3: 15.2%\\n\",\n",
    "      \"  Digit 4: 7.3%\\n\",\n",
    "      \"  Digit 5: 8.5%\\n\",\n",
    "      \"  Digit 6: 16.4%\\n\",\n",
    "      \"  Digit 7: 7.3%\\n\",\n",
    "      \"  Digit 8: 6.8%\\n\",\n",
    "      \"  Digit 9: 8.0%\\n\",\n",
    "      \"\\n\",\n",
    "      \"Predicted digit: 6\\n\",\n",
