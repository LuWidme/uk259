    "    \"print(f\\\"TensorFlow version: {tf.__version__}\\\")\\n\",\n",
    "    \"print(f\\\"Keras version: {keras.__version__}\\\")\\n\",\n",
    "    \"print(\\\"\\\\n✓ Libraries imported successfully!\\\")\"\n",
    "   ],\n",
